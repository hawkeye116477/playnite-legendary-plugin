<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="HawkeyeSeparatorStyle" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource PanelSeparatorBrush}"></Setter>
    </Style>
    <Style x:Key="HawkeyeBorderStyle" TargetType="Border" BasedOn="{StaticResource HighlightBorder}" />
    <Style x:Key="HawkeyeListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}" />
    <Style x:Key="HawkeyeTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground"
                Value="{DynamicResource TextBrush}" />
    </Style>
    <Style x:Key="HawkeyeButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}" />
    <Style x:Key="HawkeyeExpanderStyle" TargetType="{x:Type Expander}" BasedOn="{StaticResource {x:Type Expander}}" />
    <Style x:Key="HawkeyeTabControlStyle" TargetType="{x:Type TabControl}"
           BasedOn="{StaticResource {x:Type TabControl}}" />
    <Style x:Key="HawkeyeDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource {x:Type DataGrid}}" />
    <Style x:Key="HawkeyeDataGridCellStyle" TargetType="{x:Type DataGridCell}"
           BasedOn="{StaticResource {x:Type DataGridCell}}" />
    <Style x:Key="HawkeyeDataGridRowStyle" TargetType="{x:Type DataGridRow}"
           BasedOn="{StaticResource {x:Type DataGridRow}}" />
    <Style x:Key="HawkeyeDataGridColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}" />
</ResourceDictionary>